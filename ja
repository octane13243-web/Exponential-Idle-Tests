var init = () => {
    currency = theory.createCurrency();

    ///////////////////
    // Regular Upgrades
    // σ
    {
        let getDesc = (level) => "σ=" + getΣ(level).toString(0);
        let getInfo = (level) => "σ=" + getΣ(level).toString(0);
        σ = theory.createUpgrade(0, currency, new FirstFreeCost(new ExponentialCost(10, 2)));
        σ.getDescription = (amount) => Utils.getMath(getDesc(σ.level));
        σ.getInfo = (amount) => Utils.getMathTo(getInfo(σ.level), getInfo(σ.level + amount));
    }

    // χ
    {
        let getDesc = (level) => "χ=" + getΧ(level).toString(0);
        let getInfo = (level) => "χ=" + getΧ(level).toString(0);
        χ = theory.createUpgrade(1, currency, new ExponentialCost(25, 2));
        χ.getDescription = (amount) => Utils.getMath(getDesc(χ.level));
        χ.getInfo = (amount) => Utils.getMathTo(getInfo(χ.level), getInfo(χ.level + amount));
    }

    // q
    {
        let getDesc = (level) => "q=" + getQ(level).toString(0);
        let getInfo = (level) => "q=" + getQ(level).toString(0);
        q = theory.createUpgrade(2, currency, new FirstFreeCost(new ExponentialCost(10, 2)));
        q.getDescription = (amount) => Utils.getMath(getDesc(q.level));
        q.getInfo = (amount) => Utils.getMathTo(getInfo(q.level), getInfo(q.level + amount));
    }

    /////////////////////
    // Permanent Upgrades
    theory.createPublicationUpgrade(0, currency, 1e8);
    theory.createBuyAllUpgrade(1, currency, 1e15);
    theory.createAutoBuyerUpgrade(2, currency, 1e25);

    /////////////////////
    // Milestone Upgrades
    // No milestones defined

}

var tick = (elapsedTime, multiplier) => {
    let dt = BigNumber.from(elapsedTime * multiplier);
    let bonus = theory.publicationMultiplier;
    
    let vσ = getΣ(σ.level);
    let vχ = getΧ(χ.level);
    let vq = getQ(q.level);
    
    // Main equation - customize this based on your theory
    currency.value += bonus * dt * vσ * vχ * vq;
    
    theory.invalidateTertiaryEquation();
}

