}

var getPrimaryEquation = () => {
    let terms = [];

    terms.push("q_1^{" + (1 + milestone0.level * 0.05) + "}");
    terms.push("q_2");

    return theory.latexSymbol + "=" + terms.join(" ");

}

var getSecondaryEquation = () => {
    return "=\\max\\rho";
}

var getTertiaryEquation = () => {
    return "";
}

var getPublicationMultiplier = (tau) => tau.isZero ? BigNumber.ONE : tau.pow(0.15);
var getPublicationMultiplierFormula = (symbol) => "{symbol}^{0.15}";
var getTau = () => currency.value.pow(0.1);
var get2DGraphValue = () => currency.value.sign * (BigNumber.ONE + currency.value.abs()).log10().toNumber();

// Variable getters
var getQ1 = (level) => Utils.getStepwisePowerSum(level, 2, 10, 0);
var getQ2 = (level) => Utils.getStepwisePowerSum(level, 2, 10, 0);

// No story chapters

init();
