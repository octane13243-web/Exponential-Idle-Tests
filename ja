var getPrimaryEquation = () => {
    return "\\dot{\\rho} = \\int_{0}^{\\sigma} \\left( q x + \\frac{\\chi}{2} x \\right) dx";
}

var getSecondaryEquation = () => {
    return theory.latexSymbol + "=\\max\\rho";
}

