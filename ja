}

var getPrimaryEquation = () => {
    let terms = [];

    terms.push("q");
    terms.push("c^{" + (1 + milestone1.level * 0.05) + "}");

    return "\\dot{\\rho}=" + terms.join(" ");

}

var getSecondaryEquation = () => {
    return "=\\max\\rho";
}

var getTertiaryEquation = () => {
    return "";
}

var getPublicationMultiplier = (tau) => tau.isZero ? BigNumber.ONE : tau.pow(0.9);
var getPublicationMultiplierFormula = (symbol) => "{symbol}^{0.9}";
var getTau = () => currency.value.pow(0.9);
var get2DGraphValue = () => currency.value.sign * (BigNumber.ONE + currency.value.abs()).log10().toNumber();

// Variable getters
var getQ = (level) => Utils.getStepwisePowerSum(level, 2, 10, 0);
var getC = (level) => Utils.getStepwisePowerSum(level, 2, 10, 0);

// No story chapters

init();
