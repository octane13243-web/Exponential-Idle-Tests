import { ExponentialCost, FirstFreeCost, LinearCost } from "./api/Costs";
import { BigNumber } from "./api/BigNumber";
import { theory } from "./api/Theory";
import { Utils } from "./api/Utils";

var id = "number_theory";
var name = "Number Theory";
var description = "Discover the hidden structures inside integers.";
var authors = "horchata & ChatGPT";
var version = 1;


var currency;

var n;
var primePower;

var factorization;


var init = () => {

    currency = theory.createCurrency();


    ///////////////////
    // Regular Upgrades


    // Integer n
    {
        let getDesc = (level) =>
            "n=" + getN(level).toString(0);

        n = theory.createUpgrade(
            0,
            currency,
            new FirstFreeCost(
                new ExponentialCost(5, Math.log2(2))
            )
        );

        n.getDescription = (_) =>
            Utils.getMath(getDesc(n.level));

        n.getInfo = (amount) =>
            Utils.getMathTo(
                getDesc(n.level),
                getDesc(n.level + amount)
            );
    }



    // Prime Power
    {
        let getDesc = (level) =>
            "p=2^{" + level + "}";

        let getInfo = (level) =>
            "p=" + getPrimePower(level).toString(0);


        primePower = theory.createUpgrade(
            1,
            currency,
            new ExponentialCost(50, Math.log2(5))
        );


        primePower.getDescription = (_) =>
            Utils.getMath(getDesc(primePower.level));


        primePower.getInfo = (amount) =>
            Utils.getMathTo(
                getInfo(primePower.level),
                getInfo(primePower.level + amount)
            );
    }



    /////////////////////
    // Permanent Upgrades


    theory.createPublicationUpgrade(0, currency, 1);
    theory.createBuyAllUpgrade(1, currency, 1);
    theory.createAutoBuyerUpgrade(2, currency, 1);



    /////////////////////
    // Milestones


    theory.setMilestoneCost(
        new LinearCost(1,1)
    );


    factorization = theory.createMilestoneUpgrade(
        0,
        1
    );


    factorization.description =
        "Factorization";

    factorization.info =
        "Unlocks prime factor bonuses.";


    factorization.boughtOrRefunded = (_) => {
        theory.invalidatePrimaryEquation();
    };

};



var tick = (elapsedTime, multiplier) => {

    let dt = BigNumber.from(
        elapsedTime * multiplier
    );


    let production =
        getN(n.level) *
        getPrimePower(primePower.level);



    if (factorization.level > 0)
        production *= getFactorBonus(n.level);



    currency.value +=
        dt *
        theory.publicationMultiplier *
        production;

};



var getPrimaryEquation = () => {

    let equation =
        "\\dot{\\rho}=np";


    if (factorization.level > 0)
        equation += "\\cdot F(n)";


    return equation;
};



var getSecondaryEquation = () =>
    theory.latexSymbol + "=\\max\\rho";



var getPublicationMultiplier = (tau) =>
    tau.pow(0.5) / BigNumber.THREE;



var getPublicationMultiplierFormula = (symbol) =>
    "\\frac{" + symbol + "^{0.5}}{3}";



var getTau = () =>
    currency.value;



var get2DGraphValue = () =>
    currency.value.sign *
    (BigNumber.ONE + currency.value.abs())
    .log10()
    .toNumber();



////////////////////
// Math Functions



// Current integer
var getN = (level) =>
    BigNumber.from(level + 1);



// Prime contribution
var getPrimePower = (level) =>
    BigNumber.TWO.pow(level);



// Temporary factor bonus
// Will become actual factorization later
var getFactorBonus = (level) =>
    getN(level).pow(0.15);



init();