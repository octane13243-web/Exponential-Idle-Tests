import { theory } from "./api/Theory";
import { Utils } from "./api/Utils";

var id = "my_theory";
var name = "My Custom Theory";
var description = "A custom theory for Exponential Idle.";
var authors = "Your Name";
var version = 1;
var releaseOrder = "1";
var tauMultiplier = 1;

requiresGameVersion("1.4.33");

var currency;

// Variables
var q1;
var q2;

// Milestones (global — accessible from all functions)
var milestone0;

// No internal state variables

var init = () => {
    currency = theory.createCurrency();

    // Regular Upgrades
    // q1
    {
        let getDesc = (level) => "q1=" + getQ1(level).toString(0);
        let getInfo = (level) => "q1=" + getQ1(level).toString(0);
        q1 = theory.createUpgrade(0, currency, new FirstFreeCost(new ExponentialCost(10, 2)));
        q1.getDescription = (amount) => Utils.getMath(getDesc(q1.level));
        q1.getInfo = (amount) => Utils.getMathTo(getInfo(q1.level), getInfo(q1.level + amount));
    }

    // q2
    {
        let getDesc = (level) => "q2=" + getQ2(level).toString(0);
        let getInfo = (level) => "q2=" + getQ2(level).toString(0);
        q2 = theory.createUpgrade(1, currency, new FirstFreeCost(new ExponentialCost(10, 2)));
        q2.getDescription = (amount) => Utils.getMath(getDesc(q2.level));
        q2.getInfo = (amount) => Utils.getMathTo(getInfo(q2.level), getInfo(q2.level + amount));
    }

    // Permanent Upgrades
    theory.createPublicationUpgrade(0, currency, 1);
    theory.createBuyAllUpgrade(1, currency, 1e15);
    theory.createAutoBuyerUpgrade(2, currency, 1e25);

    // Milestone Upgrades
    // Milestone 1
    {
        milestone0 = theory.createMilestoneUpgrade(0, 12);
        milestone0.description = "Milestone 1";
        milestone0.info = "Milestone 1";
    }

    // Bought/refunded callbacks (invalidate equations when milestones change)
    milestone0.boughtOrRefunded = (_) => {
        theory.invalidatePrimaryEquation();
    };

    updateAvailability();
}

var tick = (elapsedTime, multiplier) => {
    let dt = BigNumber.from(elapsedTime * multiplier);
    let bonus = theory.publicationMultiplier;
    
    let exp_q1 = 1 + milestone0.level * 0.05;
    let vq1 = getQ1(q1.level).pow(exp_q1);
    let vq2 = getQ2(q2.level);

    // Build result by multiplying all variable contributions together
    let result = vq1.times(vq2);


    currency.value += bonus * dt * result;
    
    theory.invalidateTertiaryEquation();
}

