    return "";
}

var getPublicationMultiplier = (tau) => tau.isZero ? BigNumber.ONE : tau.pow(0.3);
var getPublicationMultiplierFormula = (symbol) => "{symbol}^{0.15}";
var getTau = () => currency.value.pow(1.6);
var get2DGraphValue = () => currency.value.sign * (BigNumber.ONE + currency.value.abs()).log10().toNumber();

// Variable getters
var getΣ = (level) => Utils.getStepwisePowerSum(level, 2, 10, 0);
var getΧ = (level) => BigNumber.from(3).pow(BigNumber.from(level));
var getQ = (level) => BigNumber.from(level * 1);

