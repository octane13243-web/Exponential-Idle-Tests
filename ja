import { ExponentialCost, FirstFreeCost, LinearCost } from "./api/Costs";
import { BigNumber } from "./api/BigNumber";
import { theory } from "./api/Theory";
import { Utils } from "./api/Utils";
import { ui } from "./api/ui/UI";

var id = "math_foundations";
var name = "Mathematical Foundations";
var description = "A journey through mathematics.";
var authors = "horchata & ChatGPT";
var version = 1;

var currency;

var A, P, x;
var functions;
var debugPopup;
var debugButton;

var init = () => {
    currency = theory.createCurrency();

    ///////////////////
    // Regular Upgrades

    // Arithmetic
    {
        let getDesc = (level) => "A=" + getA(level).toString(0);

        A = theory.createUpgrade(
            0,
            currency,
            new FirstFreeCost(new ExponentialCost(10, Math.log2(2)))
        );

        A.getDescription = (_) => Utils.getMath(getDesc(A.level));
        A.getInfo = (amount) =>
            Utils.getMathTo(getDesc(A.level), getDesc(A.level + amount));
    }


    // Polynomial
    {
        let getDesc = (level) => "P=2^{" + level + "}";
        let getInfo = (level) => "P=" + getP(level).toString(0);

        P = theory.createUpgrade(
            1,
            currency,
            new ExponentialCost(100, Math.log2(10))
        );

        P.getDescription = (_) => Utils.getMath(getDesc(P.level));
        P.getInfo = (amount) =>
            Utils.getMathTo(getInfo(P.level), getInfo(P.level + amount));
    }


    // Function input
    {
        let getDesc = (level) => "x=" + getX(level).toString(0);

        x = theory.createUpgrade(
            2,
            currency,
            new ExponentialCost(1000, Math.log2(8))
        );

        x.getDescription = (_) => Utils.getMath(getDesc(x.level));
        x.getInfo = (amount) =>
            Utils.getMathTo(getDesc(x.level), getDesc(x.level + amount));

        x.isAvailable = false;
    }


    /////////////////////
    // Permanent Upgrades

    theory.createPublicationUpgrade(0, currency, 1e10);
    theory.createBuyAllUpgrade(1, currency, 1e13);
    theory.createAutoBuyerUpgrade(2, currency, 1e30);


    /////////////////////
    // Debug UI

    debugPopup = ui.createPopup({
        title: "Debug Tools",
        content: ui.createStackLayout({
            children: [
                ui.createButton({
                    text: "Multiply ρ ×10",
                    onClicked: () => {
                        currency.value = currency.value * BigNumber.TEN;
                    }
                }),

                ui.createButton({
                    text: "Add 1e100 ρ",
                    onClicked: () => {
                        currency.value += BigNumber.TEN.pow(100);
                    }
                }),

                ui.createButton({
                    text: "Close",
                    onClicked: () => debugPopup.hide()
                })
            ]
        })
    });


    debugButton = theory.createUpgrade(
        99,
        currency,
        new LinearCost(0, 0)
    );

    debugButton.getDescription = (_) => "Debug Tools";
    debugButton.getInfo = (_) => "Open developer tools.";

    debugButton.boughtOrRefunded = (_) => {
        debugPopup.show();
    };


    ///////////////////////
    // Milestones

    theory.setMilestoneCost(new LinearCost(20, 20));

    functions = theory.createMilestoneUpgrade(0, 1);

    functions.description = "Functions";
    functions.info = "Unlocks logarithmic functions.";

    functions.boughtOrRefunded = (_) => {
        updateAvailability();
        theory.invalidatePrimaryEquation();
    };

    updateAvailability();
};


var updateAvailability = () => {
    x.isAvailable = functions.level > 0;
};


var tick = (elapsedTime, multiplier) => {
    let dt = BigNumber.from(elapsedTime * multiplier);

    let production =
        getA(A.level) *
        getP(P.level);

    if (functions.level > 0)
        production *= getLogTerm(x.level);

    currency.value += dt * theory.publicationMultiplier * production;
};


var getPrimaryEquation = () => {
    let equation = "\\dot{\\rho}=AP";

    if (functions.level > 0)
        equation += "\\log_2(x+2)";

    return equation;
};


var getSecondaryEquation = () =>
    theory.latexSymbol + "=\\max\\rho";


var getPublicationMultiplier = (tau) =>
    tau.pow(0.164) / BigNumber.THREE;


var getPublicationMultiplierFormula = (symbol) =>
    "\\frac{" + symbol + "^{0.164}}{3}";


var getTau = () => currency.value;


var get2DGraphValue = () =>
    currency.value.sign *
    (BigNumber.ONE + currency.value.abs()).log10().toNumber();



////////////////////
// Math Functions

var getA = (level) =>
    Utils.getStepwisePowerSum(level, 2, 10, 0);


var getP = (level) =>
    BigNumber.TWO.pow(level);


var getX = (level) =>
    Utils.getStepwisePowerSum(level, 2, 10, 0);


var getLogTerm = (level) =>
    (getX(level) + BigNumber.TWO).log() / Math.log(2);


init();