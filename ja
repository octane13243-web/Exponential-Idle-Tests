import { ExponentialCost, FirstFreeCost, CustomCost } from "./api/Costs";
import { Localization } from "./api/Localization";
import { parseBigNumber, BigNumber } from "./api/BigNumber";
import { theory } from "./api/Theory";
import { Utils } from "./api/Utils";

var id = "my_theory";
var name = "My Custom Theory";
var description = "A custom theory for Exponential Idle.";
var authors = "Your Name";
var version = 1;
var releaseOrder = "1";
var tauMultiplier = 1;

requiresGameVersion("1.4.33");

var currency;

// Variables
var q;
var c;

// Milestones (global — accessible from all functions)
var milestone1;

// No internal state variables

var init = () => {
    currency = theory.createCurrency();

    // Regular Upgrades
    // q
    {
        let getDesc = (level) => "q=" + getQ(level).toString(0);
        let getInfo = (level) => "q=" + getQ(level).toString(0);
        q = theory.createUpgrade(0, currency, new FirstFreeCost(new ExponentialCost(10, 2)));
        q.getDescription = (amount) => Utils.getMath(getDesc(q.level));
        q.getInfo = (amount) => Utils.getMathTo(getInfo(q.level), getInfo(q.level + amount));
    }

    // c
    {
        let getDesc = (level) => "c=" + getC(level).toString(0);
        let getInfo = (level) => "c=" + getC(level).toString(0);
        c = theory.createUpgrade(1, currency, new FirstFreeCost(new ExponentialCost(5, 2)));
        c.getDescription = (amount) => Utils.getMath(getDesc(c.level));
        c.getInfo = (amount) => Utils.getMathTo(getInfo(c.level), getInfo(c.level + amount));
    }

    // Permanent Upgrades
    theory.createPublicationUpgrade(0, currency, 1);
    theory.createBuyAllUpgrade(1, currency, 1e15);
    theory.createAutoBuyerUpgrade(2, currency, 1e25);

    // Milestone Upgrades
    // c 
    {
        milestone1 = theory.createMilestoneUpgrade(0, 1);
        milestone1.description = "c ";
        milestone1.info = "c ";
    }

    // Bought/refunded callbacks (invalidate equations when milestones change)
    milestone1.boughtOrRefunded = (_) => {
        theory.invalidatePrimaryEquation();
    };

    updateAvailability();
}

var tick = (elapsedTime, multiplier) => {
    let dt = BigNumber.from(elapsedTime * multiplier);
    let bonus = theory.publicationMultiplier;
    
    let vq = getQ(q.level);
    let exp_c = 1 + milestone1.level * 0.05;
    let vc = getC(c.level).pow(exp_c);

    // Build result by multiplying all variable contributions together
    let result = vq * vc;


    currency.value += bonus * dt * result;
    
    theory.invalidateTertiaryEquation();
}

